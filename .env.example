APP_NAME=AIMemory
ENVIRONMENT=production
LOG_LEVEL=INFO
LOG_FORMAT=json
SLOW_REQUEST_MS=1000
SLOW_EMBEDDING_MS=3000

DATABASE_URL=postgresql+psycopg://aimemory:aimemory@127.0.0.1:5432/aimemory
REDIS_URL=redis://127.0.0.1:6379/0

API_KEY_PREFIX=aim_

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_SESSION_SECRET=replace-with-a-random-secret
ADMIN_SESSION_MAX_AGE_SECONDS=43200
ADMIN_COOKIE_SECURE=false

EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=replace-me
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=1024
EMBEDDING_INCLUDE_DIMENSIONS=true

MAX_MEMORY_CONTENT_CHARS=20000
MAX_SEARCH_TOP_K=50
